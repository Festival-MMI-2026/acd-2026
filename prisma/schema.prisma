// Prisma schema for ACD Event Management System
// Includes better-auth tables + ACD custom models

generator client {
  provider = "prisma-client"
  output   = "../server/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// Better-Auth Tables (existing)
// ============================================

model account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime? @db.Timestamptz(6)
  refreshTokenExpiresAt DateTime? @db.Timestamptz(6)
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime  @db.Timestamptz(6)
  user                  user      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
}

model session {
  id        String   @id
  expiresAt DateTime @db.Timestamptz(6)
  token     String   @unique
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @db.Timestamptz(6)
  ipAddress String?
  userAgent String?
  userId    String
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  // Admin/Org fields
  impersonatedBy       String?


  @@index([userId])
}

model user {
  id            String    @id
  name          String    @default("")
  firstName     String    @default("")
  lastName      String    @default("")
  email         String    @unique
  emailVerified Boolean
  image         String?
  tel           String?

  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime  @default(now()) @db.Timestamptz(6)
  
  // Admin fields
  role          String?
  banned        Boolean?
  banReason     String?
  banExpires    DateTime?
  iut           String?

  account       account[]
  session       session[]
}

model verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @db.Timestamptz(6)

  @@index([identifier])
}


// ============================================
// ACD Custom Models
// ============================================

// Programme des journées
model Event {
  id          String   @id @default(uuid())
  title       String
  description String?
  date        DateTime
  startTime   String   // Format "HH:mm"
  endTime     String   // Format "HH:mm"
  location    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Repas disponibles
model Meal {
  id          String       @id @default(uuid())
  name        String       // "Déjeuner Jour 1", "Dîner Jour 2"
  description String?
  date        DateTime
  mealType    MealType
  price       Decimal      @db.Decimal(10, 2)
  options     MealOption[]
  registrationMeals RegistrationMeal[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

enum MealType {
  LUNCH
  DINNER
}

// Options de repas (entrées, plats, desserts)
model MealOption {
  id          String     @id @default(uuid())
  mealId      String
  meal        Meal       @relation(fields: [mealId], references: [id], onDelete: Cascade)
  name        String
  optionType  OptionType
  hasAllergens Boolean   @default(false)
  allergens   String[]   // Array of allergen types
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  starterChoices RegistrationMeal[] @relation("StarterOption")
  mainChoices    RegistrationMeal[] @relation("MainOption")
  cheeseChoices  RegistrationMeal[] @relation("CheeseOption")
  dessertChoices RegistrationMeal[] @relation("DessertOption")
}

enum OptionType {
  STARTER
  MAIN
  CHEESE
  DESSERT
}

// Activités sur place
model Activity {
  id              String   @id @default(uuid())
  name            String
  description     String?
  date            DateTime
  startTime       String
  endTime         String
  allDay          Boolean  @default(false)
  maxParticipants Int?
  price           Decimal  @default(0) @db.Decimal(10, 2)
  registrationActivities RegistrationActivity[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Inscriptions
model Registration {
  id          String   @id @default(uuid())
  firstName   String
  lastName    String
  email       String
  phone       String
  iutId       String?
  allergens   String?
  isMotorized Boolean @default(false)
  isVegetarian Boolean @default(false)
  isVegan      Boolean @default(false)
  noPork       Boolean @default(false)
  noAlcohol    Boolean @default(false)
  totalPrice  Decimal  @db.Decimal(10, 2)
  status      RegistrationStatus @default(PENDING)
  checkedIn   Boolean  @default(false)
  checkedInAt DateTime?
  meals       RegistrationMeal[]
  activities  RegistrationActivity[]
  order       Order?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

// Commandes / Paiements
model Order {
  id              String        @id @default(uuid())
  orderNumber     String        @unique
  registrationId  String        @unique
  registration    Registration  @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  amount          Decimal       @db.Decimal(10, 2)
  paymentStatus   PaymentStatus @default(PENDING)
  paymentMethod   PaymentMethod?
  notes           String?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CARD
  TRANSFER
  CASH
  FREE
}

// Choix de repas par inscription
model RegistrationMeal {
  id             String      @id @default(uuid())
  registrationId String
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  mealId         String
  meal           Meal        @relation(fields: [mealId], references: [id], onDelete: Cascade)
  quantity       Int         @default(1)
  
  starterOptionId String?
  starterOption   MealOption? @relation("StarterOption", fields: [starterOptionId], references: [id])
  
  mainOptionId    String?
  mainOption      MealOption? @relation("MainOption", fields: [mainOptionId], references: [id])

  cheeseOptionId  String?
  cheeseOption    MealOption? @relation("CheeseOption", fields: [cheeseOptionId], references: [id])

  dessertOptionId String?
  dessertOption   MealOption? @relation("DessertOption", fields: [dessertOptionId], references: [id])
  
  createdAt      DateTime    @default(now())
}

// Choix d'activités par inscription
model RegistrationActivity {
  id             String       @id @default(uuid())
  registrationId String
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  activityId     String
  activity       Activity     @relation(fields: [activityId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
}

// Paramètres du site
model Setting {
  id        String   @id @default("site_settings")
  showProgramme    Boolean  @default(true)
  showInscription  Boolean  @default(true)
  showActivities   Boolean  @default(true)
  showMeals        Boolean  @default(true)
  showAcces        Boolean  @default(true)
  showHotels       Boolean  @default(true)
  headerBadgeText  String   @default("Édition 2026")
  siteName         String   @default("ACD MMI 2026")
  eventDate        DateTime @default("2026-06-18T00:00:00.000Z")
  eventEndDate     DateTime @default("2026-06-19T00:00:00.000Z")
  location         String   @default("IUT de Troyes")
  locationAddress  String   @default("9 Rue de Québec, 10000 Troyes")
  notificationEmails String[] @default([])
  sendInvoicePdf     Boolean  @default(true)
  maintenanceMode    Boolean  @default(false)
  legalMentions      String   @default("")
  privacyPolicy      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Hôtels partenaires
model Hotel {
  id            String   @id @default(uuid())
  name          String
  address       String
  postalCode    String
  city          String
  latitude      Float?
  longitude     Float?
  googleMapsUrl String?
  websiteUrl    String?
  phone         String?
  email         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// IUT (Institut Universitaire de Technologie)
model Iut {
  id        String   @id @default(uuid())
  name      String
  city      String?
  code      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Contenu éditable de la page d'accueil (singleton)
model HomeContent {
  id        String   @id @default("home_content")

  // Hero Section
  heroBadge    String @default("15–17 Juin 2026 · IUT de Troyes")
  heroTitle    String @default("Assemblée des Chefs de Départements MMI")
  heroSubtitle String @default("L'IUT de Troyes accueille l'ACD MMI 2026. Un événement réunissant 34 chefs de départements.")
  heroImage    String @default("https://www.mesvitrauxfavoris.fr/Supp_e/index_htm_files/98833.jpg")

  // Tabs (JSON - includes image URLs)
  tabs         Json   @default("[{\"key\":\"partage\",\"label\":\"Partage\",\"title\":\"Échanger pour mieux construire.\",\"description\":\"L'ACD est avant tout un moment de rencontre. Profitez de ces instants pour échanger sur vos pratiques pédagogiques et vos retours d'expérience.\",\"stat\":\"50+ Chefs de départements\",\"image\":\"/gala-dinner.png\"},{\"key\":\"travail\",\"label\":\"Travail\",\"title\":\"Collaborer sur le futur.\",\"description\":\"Des ateliers dédiés à la rédaction des nouveaux référentiels. Une occasion unique d'impacter directement la formation de demain.\",\"stat\":\"34 Départements MMI\",\"image\":\"/conference-hall.png\"},{\"key\":\"decouverte\",\"label\":\"Découverte\",\"title\":\"Vivre l'expérience Troyes.\",\"description\":\"Au-delà du travail, découvrez la richesse culturelle de Troyes et sa gastronomie locale lors de nos événements conviviaux.\",\"stat\":\"Patrimoine & Gastronomie\",\"image\":\"https://static-otelico.com/cache/troyes_troyes/hotel-de-troyes-a-troyes.jpg\"}]")

  // Gradient Cards (JSON)
  gradientCards Json  @default("[{\"title\":\"Nouveaux Programmes\",\"description\":\"Adaptation au BUT\",\"features\":[\"Référentiel 2027\",\"Compétences clés\",\"Adaptation parcours\"]},{\"title\":\"Travail Collaboratif\",\"description\":\"Co-construction\",\"features\":[\"Ateliers par thèmes\",\"Partage de ressources\",\"Harmonisation\"]},{\"title\":\"Enjeux & Avenir\",\"description\":\"Stratégie MMI\",\"features\":[\"Évolution métiers\",\"Partenariats pros\",\"Conférences\"]}]")

  // Partner Logos (JSON)
  logos         Json  @default("[{\"src\":\"https://www.univ-reims.fr/iut-troyes/media-images/49449/logo-iutt.png\",\"alt\":\"IUT de Troyes\"},{\"src\":\"https://www.univ-reims.fr/ufrsesg/media-images/61471/logo_urca_blanc-removebg-preview.png\",\"alt\":\"URCA\"}]")

  // Context Section
  contextTitle String @default("Une édition tournée vers l'avenir")
  contextText  String @default("Les échanges porteront sur les nouveaux programmes nationaux du BUT MMI, qui entreront en vigueur en 2027. L'objectif est de poursuivre la rédaction du référentiel de formation afin d'adapter les programmes aux besoins et aux évolutions des métiers du numérique.")

  // Final CTA
  ctaTitle     String @default("Rejoignez l'Assemblée")
  ctaText      String @default("Participez à la construction de l'avenir du BUT MMI. Inscription obligatoire pour tous les chefs de départements.")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Contenu éditable de la page d'accès (singleton)
model AccessContent {
  id        String   @id @default("access_content")

  // Header
  pageTitle       String @default("Accès & Transports")
  pageSubtitle    String @default("Toutes les informations pour vous rendre à l'Assemblée des Chefs de Départements à Troyes.")

  // Location Card
  locationTitle    String @default("Le lieu")
  locationName     String @default("IUT de Troyes")
  locationAddress1 String @default("9 Rue de Québec")
  locationAddress2 String @default("10000 Troyes")
  locationMapUrl   String @default("https://www.google.com/maps/dir/?api=1&destination=IUT+de+Troyes")

  // Train Card
  trainTitle       String @default("Venir en train")
  trainStation     String @default("Gare de Troyes")
  trainDuration    String @default("À 1h30 de Paris-Est (TER Grand Est)")
  trainAccessTitle String @default("Accès depuis la gare")
  trainAccessLine  String @default("Bus Ligne 6 (Direction Chartreux), Arrêt \"IUT\".")
  trainAccessTime  String @default("Environ 15 minutes de trajet.")

  // Car Card
  carTitle         String @default("Venir en voiture")
  carParking       String @default("Parking gratuit disponible pour les visiteurs à l'entrée de l'IUT.")
  carAccess        String @default("Accès facile depuis l'A5 et l'A26.")

  // Map
  mapLatitude        Float  @default(48.2682678)
  mapLongitude       Float  @default(4.079772)
  mapTooltipTitle    String @default("IUT de Troyes")
  mapTooltipSubtitle String @default("Lieu de l'ACD MMI 2026")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Contenu éditable de la page programme (singleton)
model ProgrammeContent {
  id        String   @id @default("programme_content")

  pageTitle    String @default("Programme")
  pageSubtitle String @default("Retrouvez le programme complet de l'Assemblée des Chefs de Départements MMI 2026 à Troyes.")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Contenu éditable de la page inscription (singleton)
model InscriptionContent {
  id        String   @id @default("inscription_content")

  pageTitle    String @default("Inscription")
  pageSubtitle String @default("Inscrivez-vous pour participer à l'Assemblée des Chefs de Départements MMI 2026 à Troyes.")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Contenu éditable de la page hôtels (singleton)
model HotelsContent {
  id        String   @id @default("hotels_content")

  pageTitle    String @default("Hébergements à Troyes")
  pageSubtitle String @default("Découvrez nos hôtels partenaires pour votre séjour lors de l'Assemblée des Chefs de Départements MMI.")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Journal d'activité (Audit Log)
model AuditLog {
  id         String   @id @default(uuid())
  action     String   // e.g. "registration.created", "order.paid", "registration.checkin"
  entityType String   // e.g. "Registration", "Order"
  entityId   String
  userId     String?  // Admin who performed the action (nullable for system actions)
  metadata   Json?    // Additional details
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}
